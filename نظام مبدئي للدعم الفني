          </thead>
          <tbody id="employeesTableBody"></tbody>
        </table>
        </div>
      </div>
    </div>

    <!-- Issue types management -->
    <div class="card">
      <div class="card-body">
        <div class="section-title">إضافة نوع مشكلة جديد</div>
        <div class="admin-add-grid issue-grid">
          <div class="field">
            <label>نوع المشكلة</label>
            <input type="text" id="newIssueName" placeholder="مثال: تعليق النظام">
          </div>
          <div class="field">
            <label>التصنيف</label>
            <input type="text" id="newIssueCategory" list="categoryList" placeholder="اختر تصنيفاً أو اكتب تصنيفاً جديداً">
            <datalist id="categoryList"></datalist>
          </div>
          <div class="field">
            <label>الحل (اختياري)</label>
            <input type="text" id="newIssueSolution" placeholder="اكتب الحل إن وجد">
          </div>
          <button class="btn-primary" onclick="addIssueType()">إضافة</button>
        </div>

        <div class="divider"></div>

        <div class="section-title">قائمة أنواع المشاكل</div>
        <div style="overflow-x:auto;">
        <table>
          <thead>
            <tr>
              <th>نوع المشكلة</th>
              <th>التصنيف</th>
              <th>الحل</th>
              <th>حذف</th>
            </tr>
          </thead>
          <tbody id="issueTypesTableBody"></tbody>
        </table>
        </div>
      </div>
    </div>

    <!-- All requests -->
    <div class="card">
      <div class="table-wrap">
        <h2>جميع الطلبات</h2>
        <div style="overflow-x:auto;">
        <table>
          <thead>
            <tr>
              <th>الرقم الوظيفي</th>
              <th>اسم الموظف</th>
              <th>الايميل الرسمي</th>
              <th>تفاصيل الخدمة</th>
              <th>الاجراء المتخذ</th>
              <th>الحالة</th>
            </tr>
          </thead>
          <tbody id="adminTableBody"></tbody>
        </table>
        </div>

        <div class="filters-row">
          <button class="btn-primary" onclick="printRequests()">طباعة</button>
          <div class="field">
            <label>من تاريخ</label>
            <input type="date" id="filterFrom">
          </div>
          <div class="field">
            <label>الى تاريخ</label>
            <input type="date" id="filterTo">
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
/* ===================== Admin password ===================== */
const ADMIN_PASSWORD = "0581789770";

/* ===================== In-memory data ===================== */
let employees = [
  { empNo: "2020", name: "محمد علي محمد خالدي", email: "msjjsa@momah.gov.sa" },
  { empNo: "20202", name: "منصور مفرح المالكي", email: "" }
];

let categories = ["أنظمة", "أجهزة", "طابعات", "ماسح ضوئي", "شبكة نت", "أخرى"];

let issueTypes = [
  { name: "أنظمة", category: "أنظمة", solution: "" },
  { name: "أجهزة", category: "أجهزة", solution: "" },
  { name: "طابعات", category: "طابعات", solution: "" },
  { name: "ماسح ضوئي", category: "ماسح ضوئي", solution: "" },
  { name: "شبكة نت", category: "شبكة نت", solution: "" }
];

const ACTION_OPTIONS = ["-اخر-", "جديد", "تثبيت", "صيانة", "فورمات", "ربط كلمة مرور", "منجز"];
const STATUS_OPTIONS = ["قيد المراجعة", "حفظ", "منجز"];

let requests = [
  {
    empNo: "2020",
    empName: "محمد علي محمد خالدي",
    email: "msjjsa@momah.gov.sa",
    service: "أنظمة - شبكات",
    action: "منجز",
    status: "حفظ",
    date: "2026-03-05"
  }
];

let currentEmployee = null; // { empNo, name, email }
let editingEmpIndex = null; // index of employee currently being edited in admin table
let isDarkTheme = false;

/* ===================== Theme ===================== */
function toggleTheme(){
  isDarkTheme = !isDarkTheme;
  document.body.classList.toggle("dark-theme", isDarkTheme);
  document.querySelectorAll(".theme-toggle-btn").forEach(btn=>{
    btn.textContent = isDarkTheme ? "☀️ فاتح" : "🌙 غامق";
  });
}

/* ===================== Date/time header ===================== */
function formatDateTime(){
  const now = new Date();
  const days = ["الأحد","الإثنين","الثلاثاء","الأربعاء","الخميس","الجمعة","السبت"];
  const months = ["يناير","فبراير","مارس","أبريل","مايو","يونيو","يوليو","أغسطس","سبتمبر","أكتوبر","نوفمبر","ديسمبر"];
  const dayName = days[now.getDay()];
  const day = now.getDate();
  const month = months[now.getMonth()];
  const year = now.getFullYear();
  let hours = now.getHours();
  const minutes = now.getMinutes().toString().padStart(2,"0");
  const ampm = hours >= 12 ? "م" : "ص";
  hours = hours % 12; if(hours === 0) hours = 12;
  return `${dayName}، ${day} ${month} ${year}<br>${hours}:${minutes} ${ampm}`;
}
function tickClock(){
  const str = formatDateTime();
  ["dt-employee","dt-myreq","dt-admin"].forEach(id=>{
    const el = document.getElementById(id);
    if(el) el.innerHTML = str;
  });
}
setInterval(tickClock, 1000*30);

/* ===================== View switching ===================== */
function hideAll(){
  ["view-login","view-admin-login","view-employee","view-my-requests","view-admin"].forEach(id=>{
    document.getElementById(id).classList.add("hidden");
  });
}
function showLogin(){
  hideAll();
  document.getElementById("view-login").classList.remove("hidden");
  document.getElementById("loginEmpNo").value = "";
  document.getElementById("loginError").style.display = "none";
}
function showAdminLogin(){
  hideAll();
  document.getElementById("view-admin-login").classList.remove("hidden");
  document.getElementById("adminPass").value = "";
  document.getElementById("adminError").style.display = "none";
}
function showEmployeeHome(){
  hideAll();
  document.getElementById("view-employee").classList.remove("hidden");
  document.getElementById("empWelcomeName").textContent = currentEmployee.name;
  document.getElementById("empEmail").value = currentEmployee.email || "";
  document.getElementById("empName").value = currentEmployee.name;
  document.getElementById("empNo").value = currentEmployee.empNo;
  populateServiceDropdown();
  document.getElementById("otherDetails").value = "";
  document.getElementById("otherBoxRow").style.display = "none";
  tickClock();
}
function showMyRequests(){
  hideAll();
  document.getElementById("view-my-requests").classList.remove("hidden");
  document.getElementById("myReqWelcomeName").textContent = currentEmployee.name;
  renderMyRequests();
  tickClock();
}
function showAdmin(){
  hideAll();
  document.getElementById("view-admin").classList.remove("hidden");
  editingEmpIndex = null;
  populateCategoryList();
  renderEmployeesTable();
  renderIssueTypesTable();
  renderAdminTable();
  tickClock();
}

/* ===================== Login handlers ===================== */
function handleLogin(){
  const empNo = document.getElementById("loginEmpNo").value.trim();
  const errEl = document.getElementById("loginError");
  if(!empNo){
    errEl.textContent = "الرجاء إدخال رقم الموظف";
    errEl.style.display = "block";
    return;
  }
  const emp = employees.find(e => e.empNo === empNo);
  if(!emp){
    errEl.textContent = "رقم الموظف غير مسجل، تواصل مع المسؤول لإضافتك";
    errEl.style.display = "block";
    return;
  }
  errEl.style.display = "none";
  currentEmployee = { empNo: emp.empNo, name: emp.name, email: emp.email };
  showEmployeeHome();
}
function handleAdminLogin(){
  const pass = document.getElementById("adminPass").value;
  const errEl = document.getElementById("adminError");
  if(pass !== ADMIN_PASSWORD){
    errEl.style.display = "block";
    return;
  }
  errEl.style.display = "none";
  showAdmin();
}
function handleLogout(){
  currentEmployee = null;
  showLogin();
}

/* ===================== Employee form logic ===================== */
function populateServiceDropdown(){
  const sel = document.getElementById("serviceType");
  sel.innerHTML = '<option value="">اختر خدمة-</option>';
  issueTypes.forEach(it => {
    const opt = document.createElement("option");
    opt.value = it.name;
    opt.textContent = `${it.category} - ${it.name}`;
    sel.appendChild(opt);
  });
  const otherOpt = document.createElement("option");
  otherOpt.value = "اخرى";
  otherOpt.textContent = "اخرى";
  sel.appendChild(otherOpt);
}
function onServiceTypeChange(){
  const val = document.getElementById("serviceType").value;
  document.getElementById("otherBoxRow").style.display = (val === "اخرى") ? "flex" : "none";
}
function submitRequest(){
  const service = document.getElementById("serviceType");
  if(!service.value){
    alert("الرجاء اختيار تفاصيل الخدمة");
    return;
  }
  let serviceText;
  if(service.value === "اخرى"){
    const other = document.getElementById("otherDetails").value.trim();
    if(!other){
      alert("الرجاء كتابة تفاصيل الخدمة المطلوبة");
      return;
    }
    serviceText = "أخرى - " + other;
  } else {
    const match = issueTypes.find(it => it.name === service.value);
    serviceText = match ? `${match.category} - ${match.name}` : service.value;
  }
  const today = new Date().toISOString().slice(0,10);
  requests.push({
    empNo: currentEmployee.empNo,
    empName: currentEmployee.name,
    email: document.getElementById("empEmail").value.trim(),
    service: serviceText,
    action: "-اخر-",
    status: "قيد المراجعة",
    date: today
  });
  alert("تم إرسال الطلب بنجاح");
  showMyRequests();
}

/* ===================== Admin: employees management ===================== */
function addEmployee(){
  const no = document.getElementById("newEmpNo").value.trim();
  const name = document.getElementById("newEmpName").value.trim();
  const email = document.getElementById("newEmpEmail").value.trim();
  if(!no || !name){
    alert("الرجاء إدخال رقم الموظف واسمه");
    return;
  }
  if(employees.some(e => e.empNo === no)){
    alert("رقم الموظف مسجل مسبقًا");
    return;
  }
  employees.push({ empNo: no, name, email });
  document.getElementById("newEmpNo").value = "";
  document.getElementById("newEmpName").value = "";
  document.getElementById("newEmpEmail").value = "";
  renderEmployeesTable();
}
function deleteEmployee(empNo){
  if(!confirm("هل تريد حذف هذا الموظف؟")) return;
  employees = employees.filter(e => e.empNo !== empNo);
  editingEmpIndex = null;
  renderEmployeesTable();
}
function editEmployee(index){
  editingEmpIndex = index;
  renderEmployeesTable();
}
function cancelEmployeeEdit(){
  editingEmpIndex = null;
  renderEmployeesTable();
}
function saveEmployeeEdit(index){
  const noEl = document.getElementById("editEmpNo_" + index);
  const nameEl = document.getElementById("editEmpName_" + index);
  const emailEl = document.getElementById("editEmpEmail_" + index);
  const no = noEl.value.trim();
  const name = nameEl.value.trim();
  const email = emailEl.value.trim();
  if(!no || !name){
    alert("الرجاء إدخال رقم الموظف واسمه");
    return;
  }
  if(employees.some((e, i) => e.empNo === no && i !== index)){
    alert("رقم الموظف مستخدم مسبقًا لموظف آخر");
    return;
  }
  employees[index] = { empNo: no, name, email };
  editingEmpIndex = null;
  renderEmployeesTable();
}
function renderEmployeesTable(){
  const tbody = document.getElementById("employeesTableBody");
  tbody.innerHTML = "";
  if(employees.length === 0){
    tbody.innerHTML = `<tr class="empty-row"><td colspan="4">لا يوجد موظفون بعد</td></tr>`;
    return;
  }
  employees.forEach((e, idx) => {
    if(editingEmpIndex === idx){
      tbody.innerHTML += `
        <tr>
          <td data-label="رقم الموظف"><input class="edit-input" type="text" id="editEmpNo_${idx}" value="${e.empNo}"></td>
          <td data-label="اسم الموظف"><input class="edit-input" type="text" id="editEmpName_${idx}" value="${e.name}"></td>
          <td data-label="الايميل الرسمي"><input class="edit-input" type="email" id="editEmpEmail_${idx}" value="${e.email || ""}"></td>
          <td data-label="إجراء">
            <div class="row-action-btns">
              <button class="btn-secondary" style="padding:6px 14px;font-size:12px;" onclick="saveEmployeeEdit(${idx})">حفظ</button>
              <button class="btn-danger" onclick="cancelEmployeeEdit()">إلغاء</button>
            </div>
          </td>
        </tr>`;
    } else {
      tbody.innerHTML += `
        <tr>
          <td data-label="رقم الموظف">${e.empNo}</td>
          <td data-label="اسم الموظف">${e.name}</td>
          <td data-label="الايميل الرسمي">${e.email || "-"}</td>
          <td data-label="إجراء">
            <div class="row-action-btns">
              <button class="btn-secondary" style="padding:6px 14px;font-size:12px;" onclick="editEmployee(${idx})">تعديل</button>
              <button class="btn-danger" onclick="deleteEmployee('${e.empNo}')">حذف</button>
            </div>
          </td>
        </tr>`;
    }
  });
}

/* ===================== Admin: issue types & categories management ===================== */
function populateCategoryList(){
  const dl = document.getElementById("categoryList");
  dl.innerHTML = "";
  categories.forEach(c => {
    const opt = document.createElement("option");
    opt.value = c;
    dl.appendChild(opt);
  });
}
function addIssueType(){
  const name = document.getElementById("newIssueName").value.trim();
  const category = document.getElementById("newIssueCategory").value.trim();
  const solution = document.getElementById("newIssueSolution").value.trim();
  if(!name){
    alert("الرجاء إدخال نوع المشكلة");
    return;
  }
  if(!category){
    alert("الرجاء إدخال أو اختيار التصنيف");
    return;
  }
  if(!categories.includes(category)){
    categories.push(category);
    populateCategoryList();
  }
  issueTypes.push({ name, category, solution });
  document.getElementById("newIssueName").value = "";
  document.getElementById("newIssueCategory").value = "";
  document.getElementById("newIssueSolution").value = "";
  renderIssueTypesTable();
}
function deleteIssueType(index){
  if(!confirm("هل تريد حذف نوع المشكلة هذا؟")) return;
  issueTypes.splice(index, 1);
  renderIssueTypesTable();
}
function renderIssueTypesTable(){
  const tbody = document.getElementById("issueTypesTableBody");
  tbody.innerHTML = "";
  if(issueTypes.length === 0){
    tbody.innerHTML = `<tr class="empty-row"><td colspan="4">لا توجد أنواع مشاكل بعد</td></tr>`;
    return;
  }
  issueTypes.forEach((it, idx) => {
    tbody.innerHTML += `
      <tr>
        <td data-label="نوع المشكلة">${it.name}</td>
        <td data-label="التصنيف">${it.category}</td>
        <td data-label="الحل">${it.solution || "-"}</td>
        <td data-label="حذف"><button class="btn-danger" onclick="deleteIssueType(${idx})">حذف</button></td>
      </tr>`;
  });
}

/* ===================== Tables: requests ===================== */
function renderMyRequests(){
  const tbody = document.getElementById("myReqTableBody");
  const mine = requests.filter(r => r.empNo === currentEmployee.empNo);
  tbody.innerHTML = "";
  if(mine.length === 0){
    tbody.innerHTML = `<tr class="empty-row"><td colspan="6">لا توجد طلبات بعد</td></tr>`;
    return;
  }
  mine.forEach(r => {
    tbody.innerHTML += `
      <tr>
        <td data-label="الرقم الوظيفي">${r.empNo}</td>
        <td data-label="اسم الموظف">${r.empName}</td>
        <td data-label="الايميل الرسمي">${r.email || "-"}</td>
        <td data-label="تفاصيل الخدمة">${r.service}</td>
        <td data-label="الاجراء المتخذ">${r.action}</td>
        <td data-label="الحالة">${statusBadge(r.status)}</td>
      </tr>`;
  });
}

function statusBadge(status){
  let cls = "pending";
  if(status === "منجز") cls = "done";
  else if(status === "حفظ") cls = "saved";
  return `<span class="badge ${cls}">${status}</span>`;
}

function renderAdminTable(){
  const tbody = document.getElementById("adminTableBody");
  const from = document.getElementById("filterFrom").value;
  const to = document.getElementById("filterTo").value;
  let list = requests.slice();
  if(from) list = list.filter(r => r.date >= from);
  if(to) list = list.filter(r => r.date <= to);

  tbody.innerHTML = "";
  if(list.length === 0){
    tbody.innerHTML = `<tr class="empty-row"><td colspan="6">لا توجد طلبات ضمن الفترة المحددة</td></tr>`;
    return;
  }
  list.forEach((r) => {
    const realIndex = requests.indexOf(r);
    const actionOptions = ACTION_OPTIONS.map(o =>
      `<option value="${o}" ${r.action===o?"selected":""}>${o}</option>`
    ).join("");
    const statusOptions = STATUS_OPTIONS.map(s =>
      `<option value="${s}" ${r.status===s?"selected":""}>${s}</option>`
    ).join("");
    tbody.innerHTML += `
      <tr>
        <td data-label="الرقم الوظيفي">${r.empNo}</td>
        <td data-label="اسم الموظف">${r.empName}</td>
        <td data-label="الايميل الرسمي">${r.email || "-"}</td>
        <td data-label="تفاصيل الخدمة">${r.service}</td>
        <td data-label="الاجراء المتخذ">
          <select class="status-select" onchange="updateAction(${realIndex}, this.value)">
            ${actionOptions}
          </select>
        </td>
        <td data-label="الحالة">
          <select class="mini-select" onchange="updateStatus(${realIndex}, this.value)">
            ${statusOptions}
          </select>
        </td>
      </tr>`;
  });
}
function updateAction(index, value){
  requests[index].action = value;
  if(value === "منجز"){
    requests[index].status = "منجز";
  }
  renderAdminTable();
}
function updateStatus(index, value){
  requests[index].status = value;
  renderAdminTable();
}
document.addEventListener("input", (e)=>{
  if(e.target.id === "filterFrom" || e.target.id === "filterTo"){
    renderAdminTable();
  }
});

function printRequests(){
  window.print();
}

/* ===================== Init ===================== */
tickClock();
showLogin();
</script>

