  </div>
</div>

<!-- ===================== ADMIN DASHBOARD VIEW ===================== -->
<div id="view-admin" class="hidden">
  <div class="topbar">
    <div class="nav-group">
      <button class="nav-btn" onclick="handleLogout()">تسجيل خروج</button>
      <button class="nav-btn theme-toggle-btn" onclick="toggleTheme()">🌙 غامق</button>
    </div>
    <div style="display:flex; align-items:center; gap:20px;">
      <div class="datetime" id="dt-admin"></div>
      <div class="brand">
        <div class="titles">
          <h1>نظام التحول الرقمي | دعم</h1>
          <p>بلدية محافظة صبيا</p>
        </div>
        <div class="logo">أ</div>
      </div>
    </div>
  </div>

  <div class="container">

    <!-- Welcome + management: employees -->
    <div class="card">
      <div class="welcome">مرحبا بك: مسؤول النظام</div>
      <div class="card-body">
        <div class="section-title">إضافة موظف جديد</div>
        <div class="admin-add-grid">
          <div class="field">
            <label>رقم الموظف</label>
            <input type="text" id="newEmpNo" placeholder="مثال: 2033">
          </div>
          <div class="field">
            <label>اسم الموظف</label>
            <input type="text" id="newEmpName" placeholder="اسم الموظف">
          </div>
          <div class="field">
            <label>الايميل الرسمي</label>
            <input type="email" id="newEmpEmail" placeholder="name@momah.gov.sa">
          </div>
          <button class="btn-primary" onclick="addEmployee()">إضافة</button>
        </div>

        <div class="divider"></div>

        <div class="section-title">قائمة الموظفين</div>
        <div style="overflow-x:auto;">
        <table>
          <thead>
            <tr>
              <th>رقم الموظف</th>
              <th>اسم الموظف</th>
              <th>الايميل الرسمي</th>
